{
  "rebuild_data": false,
  "raw_data_path": "data/raw/compustat_raw.csv",
  "clean_data_path": "data/clean/compustat_clean.csv",

  "theta0": [0.1, 0.1],

  "bounds": [
    [0.0001, 10.0],
    [0.0001, 10.0]
  ],

  "n_moments": 12,

  "model": {
    "alpha": 0.75,
    "delta": 0.15,
    "rho": 0.70,
    "sigma": 0.40,
    "profit_intercept": 0.00,
    "production_scale": 0.55,
    "fixed_cost": 18.0
  },

  "simulation": {
    "n_firms": 2000,
    "t_periods": 60,
    "burn_in": 10,
    "seed": 123,

    "initial_capital": 100.0,
    "initial_log_z": 0.0,
    "start_year": 2000,

    "sigma_i": 0.22,
    "sigma_lev": 0.12,
    "sigma_cash": 0.07,

    "debt_adjust_speed": 0.22,
    "cash_adjust_speed": 0.14,
    "investment_adjust_speed": 0.65,

    "asset_multiplier": 1.5,
    "use_dynamic_solver": true
  },

  "dp": {
    "beta": 0.95,

    "k_grid_size": 41,
    "k_min": 10.0,
    "k_max": 300.0,

    "z_grid_size": 7,
    "tauchen_m": 2.5,

    "control_grid_size": 181,
    "investment_min": -0.35,
    "investment_max": 0.50,

    "max_iter": 500,
    "tol": 1e-6,

    "policy_lower_bound_tolerance": 1e-8,
    "policy_upper_bound_tolerance": 1e-8
  }
}